# ================================================================
# GymFuel — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only .env.example is safe to commit
# ================================================================

# ── Application ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/gymfuel
# Staging / Prod: use MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/gymfuel
REDIS_URI=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# JWT for Admin Panel (shorter expiry for security)
ADMIN_JWT_SECRET=your_admin_jwt_secret_minimum_32_characters_long
ADMIN_JWT_EXPIRES_IN=8h

# ── Firebase (Google One-Tap Auth) ───────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Note: Replace literal \n with actual newlines when setting in .env
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Cloudinary (Image Storage) ───────────────────────────────────
# Get from cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google Gemini AI ─────────────────────────────────────────────
# Get from aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Web Push (PWA Push Notifications) ───────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@gymfuel.com

# ── Email (Nodemailer) ───────────────────────────────────────────
# For sending password resets, notifications, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=GymFuel <noreply@gymfuel.com>

# ── External Food APIs ────────────────────────────────────────────
# Open Food Facts is free — no key needed
# USDA FoodData Central: api.nal.usda.gov
USDA_API_KEY=your_usda_api_key_here

# Nutritionix (optional — 500 req/day free tier)
NUTRITIONIX_APP_ID=your_app_id
NUTRITIONIX_APP_KEY=your_app_key

# ── Frontend Apps (Vite environment variables) ───────────────────
# These get embedded at build time — safe to be public
VITE_API_URL=http://localhost:5000
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── CORS Origins ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Rate Limiting ─────────────────────────────────────────────────
# Maximum requests per IP per 15-minute window
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=info
