{
  "name": "gymfuel-root",
  "private": true,
  "scripts": {
    "dev:all": "concurrently -n user,admin,landing,server -c blue,magenta,cyan,green \"pnpm --filter gymfuel-user dev\" \"pnpm --filter gymfuel-admin dev\" \"pnpm --filter gymfuel-landing dev\" \"pnpm --filter gymfuel-server dev\"",
    "build:all": "pnpm -r run build",
    "test:all": "pnpm -r run test",
    "lint:all": "eslint .",
    "typecheck:all": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.20.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.24.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,html,css}": [
      "prettier --write"
    ]
  }
}
